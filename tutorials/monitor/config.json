      "title": "El problema con /loop",
      "lines": [
        { "kind": "command", "text": "/loop 2m \"avisa si falla algun test\"" },
        { "kind": "blank", "text": "" },
        { "kind": "output", "text": "[llamada 1/4 — sin fallos]" },
        { "kind": "output", "text": "[llamada 2/4 — sin fallos]" },
